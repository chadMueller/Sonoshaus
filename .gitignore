# Secrets — never commit (copy from .env.example)
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Build outputs (regenerate with `npm run build`)
dist/

# Electron: ignore unpacked apps and metadata; keep macOS `.dmg` installers (see README)
release/*
!release/*.dmg
out/

# Local dev certs (contains private key)
.certs/

# OS / editor
.DS_Store
*.log
.idea/
.vscode/
*.swp
*.swo

# Debug / local
*.local
coverage/
.vercel
