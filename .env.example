# =============================================================================
# Sonoshaus — copy to `.env` and adjust (never commit `.env`)
# =============================================================================

# Required: URL of node-sonos-http-api (bridge). Use localhost if bridge runs
# on this machine, or http://<LAN_IP>:5005 if it runs elsewhere on your network.
# This value is baked into the client at build time (Vite).
# Users can override at runtime in the app (Bridge Setup screen) without rebuilding.
VITE_SONOS_API_URL=http://localhost:5005

# Optional: use mock Sonos data in the UI (development / no bridge)
# VITE_SONOS_FORCE_MOCK=false

# Optional: kiosk-style behavior (fullscreen + idle reload)
# VITE_KIOSK_FULLSCREEN=true
# VITE_KIOSK_IDLE_MINUTES=45

# -----------------------------------------------------------------------------
# Optional: Spotify album rack (OAuth PKCE — no client secret needed)
# Do NOT use real secrets in any variable prefixed with VITE_ — those are
# exposed in the browser bundle. PKCE uses *only* a Client ID.
# -----------------------------------------------------------------------------
# 1. Create an app in the Spotify dev dashboard
# 2. Add this redirect URI: https://sonos-ten.vercel.app/callback/
# 3. Copy your Client ID below
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_REDIRECT_URI=https://sonos-ten.vercel.app/callback/
