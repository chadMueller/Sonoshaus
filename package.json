{
  "name": "sonos-controller",
  "private": true,
  "version": "0.7.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"python3 https-proxy.py\"",
    "build": "vite build",
    "preview": "vite preview",
    "prepare-bridge": "bash scripts/prepare-bridge.sh",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron electron/main.cjs\"",
    "desktop:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.8",
    "vite": "^6.4.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.chadmueller.sonosreceiver",
    "productName": "Sonohaus",
    "icon": "build/icon.icns",
    "compression": "maximum",
    "electronLanguages": [
      "en"
    ],
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts/install-bridge.command",
        "to": "bridge-installer/install-bridge.command"
      },
      {
        "from": "scripts/bridge-watchdog.sh",
        "to": "bridge-installer/bridge-watchdog.sh"
      },
      {
        "from": "scripts/token-server.cjs",
        "to": "bridge-installer/token-server.cjs"
      }
    ],
    "dmg": {
      "format": "ULFO",
      "background": "build/dmg-background.png",
      "window": {
        "width": 660,
        "height": 420
      },
      "iconSize": 112,
      "contents": [
        {
          "x": 160,
          "y": 290,
          "type": "file"
        },
        {
          "x": 500,
          "y": 290,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.music"
    }
  }
}
